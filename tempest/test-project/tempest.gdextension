[configuration]

entry_symbol = "tempest_library_init"
compatibility_minimum = "4.4"
reloadable = true

[libraries]

macos.debug = "res://bin/libtempest.macos.template_debug.universal.dylib"
macos.release = "res://bin/libtempest.macos.template_debug.universal.dylib"
linux.debug.x86_64 = "res://../tempest/bin/libtempest.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://../tempest/bin/libtempest.linux.template_release.x86_64.so"
windows.debug.x86_64 = "res://../tempest/bin/libtempest.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://../tempest/bin/libtempest.windows.template_release.x86_64.dll"
