; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited from a text editor.
; Format: Godot 4 project.godot

[application]

config/name="Kinetic Test Project"
config/description="Test project for the Kinetic motion matching plugin."
run/main_scene="res://test_scene.tscn"
config/features=PackedStringArray("4.3")

[editor_plugins]

enabled=PackedStringArray("res://addons/kinetic/plugin.cfg")

